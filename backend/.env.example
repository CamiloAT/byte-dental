# Backend - ByteDental
# Copy this file to .env and fill in your values

# Database
DATABASE_URL=postgresql+psycopg://<db_user>:<db_password>@<db_host>:<db_port>/<db_name>
DB_HOST=localhost
DB_PORT=5433
DB_NAME=bytedental_db
DB_USER=bytedental_user
DB_PASSWORD=bytedental_password

# Firebase
FIREBASE_CREDENTIALS_PATH=<path-to-firebase-adminsdk-json>
FIREBASE_API_KEY=<firebase-web-api-key>

# SMTP (Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=<your-email@gmail.com>
SMTP_PASSWORD=<your-app-password>
SMTP_TLS=True
SMTP_SSL=False

# SendGrid (optional, overrides SMTP if USE_SENDGRID=true)
SENDGRID_API_KEY=<your-sendgrid-api-key>
USE_SENDGRID=false

# App
APP_NAME=ByteDental Email Service
FROM_EMAIL=<your-email@gmail.com>
FROM_NAME=ByteDental
FRONTEND_URL=http://localhost:5173
